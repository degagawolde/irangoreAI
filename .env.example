# Chatbot Backend Configuration

# ======================
# Server Configuration
# ======================
DEBUG=false
LOG_LEVEL=INFO

# ======================
# Neo4j Configuration
# ======================
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# ======================
# LLM Configuration
# ======================
# Provider: ollama, openai, anthropic, etc.
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:8b
LLM_TEMPERATURE=0.7
EMBEDDING_MODEL=qwen3-embedding

# ======================
# Ollama Configuration (if using Ollama)
# ======================
OLLAMA_BASE_URL=http://localhost:11434

# ======================
# OpenAI Configuration (if using OpenAI)
# ======================
# OPENAI_API_KEY=your-api-key-here
# OPENAI_MODEL=gpt-4

# ======================
# Vector Store Configuration
# ======================
VECTOR_INDEX_NAME=documents
VECTOR_NODE_LABEL=Chunk
VECTOR_TEXT_PROPERTY=text
VECTOR_EMBEDDING_PROPERTY=embedding

# ======================
# Session Configuration
# ======================
SESSION_TIMEOUT=3600
MAX_HISTORY_LENGTH=50

# ======================
# SQL / File / DarkIntel Connectors
# ======================
# SQL_DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/dbname
FILE_DATA_ROOT=./_files
# SERPER_API_KEY=your-serper-api-key
# DARKINTEL_API_URL=https://your-darkintel-provider/api/search
# DARKINTEL_API_KEY=your-darkintel-api-key
